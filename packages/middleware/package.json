{
  "name": "@eesimple/middleware",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.13.1",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc -p tsconfig.build.json && tsc-alias -p tsconfig.build.json --resolve-full-paths",
    "clean": "rm -rf dist tsconfig.build.tsbuildinfo",
    "dev": "nodemon --quiet --watch src --ext ts --exec \"tsx src/index.ts\"",
    "start": "node dist/index.js",
    "test": "node --test --import tsx \"./src/tests/**/*.test.ts\"",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "migrate:dev": "dotenv -e .env -- tsx src/db/migrate.ts",
    "migrate:prod": "node dist/db/migrate.js",
    "push:dev": "pnpm run migrate:dev && dotenv -e .env -- drizzle-kit push",
    "push:prod": "pnpm run migrate:prod && drizzle-kit push",
    "studio": "dotenv -e .env -- drizzle-kit studio"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "3.1073.0",
    "@eesimple/types": "workspace:*",
    "@fastify/cors": "11.2.0",
    "@fastify/multipart": "10.0.0",
    "@fastify/swagger": "9.7.0",
    "@fastify/swagger-ui": "6.0.0",
    "@turf/helpers": "^7.3.5",
    "@turf/union": "^7.3.5",
    "dotenv": "17.4.2",
    "drizzle-kit": "0.31.10",
    "drizzle-orm": "0.45.2",
    "fastify": "5.8.5",
    "pdfjs-dist": "6.1.200",
    "pg": "8.22.0",
    "sharp": "0.35.2"
  },
  "devDependencies": {
    "@types/node": "26.0.0",
    "@types/pg": "8.20.0",
    "dotenv-cli": "11.0.0",
    "nodemon": "3.1.14",
    "pino-pretty": "^13.1.3",
    "tsc-alias": "1.8.17",
    "tsx": "4.22.4",
    "typescript": "5.9.3"
  }
}
