# PostgreSQL connection string used by Drizzle and the Fastify API.
# Matches the local docker-compose database (see repo-root docker-compose.yml).
DATABASE_URL=postgresql://postgres:password@localhost:5432/bookmarks

# Optional: override the API port (defaults to 3001).
# PORT=3001

# Optional: expose the Swagger/OpenAPI docs at /docs. Defaults to on outside production and off in
# production. Set to `true` to also serve them through the production gateway (the API is
# unauthenticated, so this makes the full API surface publicly explorable — enable deliberately).
# DOCS_ENABLED=true

# Object storage (Garage / any S3-compatible store) for bookmark images.
# For `pnpm dev` the middleware runs on the host, so point at the host-mapped Garage port.
# Fill ACCESS_KEY_ID / SECRET_ACCESS_KEY with the key created during the one-time Garage
# bootstrap (see README → "Object storage (Garage)"). Image routes return 503 until these are set.
S3_ENDPOINT=http://localhost:3900
S3_REGION=garage
S3_BUCKET=bookmarks
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=

# Optional Tier 2 metadata connectors — all DEFAULT OFF (the keyless scrape/oEmbed path is used when
# unset). Setting these is what sends URLs to a third party; the pipeline behaves identically without
# them. Status is shown on Settings → Connectors.
#
# Hosted metadata provider (Browserless) for JS-rendered / bot-protected pages.
# Run: docker run -p 3000:3000 ghcr.io/browserless/chromium
# These can also be configured from the Settings → Connectors page in the app.
# HOSTED_METADATA_ENDPOINT=http://localhost:3000
# HOSTED_METADATA_API_KEY=
# HOSTED_METADATA_PROVIDER=browserless
#
# Secret key used to encrypt API keys stored via the Connectors settings page. Set to a long
# random string (e.g. `openssl rand -hex 32`). Without this, API keys are stored as plaintext
# but are still never returned via the API.
# APP_SECRET=
#
# YouTube Data API v3 key — replaces the watch-page scrape for duration/date/description when set.
# YOUTUBE_API_KEY=
#
# Instagram profile API (Tier 2, default off) — when set, author avatars / profile data come from a
# third-party Instagram profile API instead of the keyless public-embed scrape (which stays the
# fallback). INSTAGRAM_API_ENDPOINT is a URL template with a `{handle}` placeholder returning JSON
# with `profile_pic_url_hd` / `profile_pic_url`; INSTAGRAM_API_KEY is sent as a Bearer token.
# INSTAGRAM_API_KEY=
# INSTAGRAM_API_ENDPOINT=https://example.com/instagram/{handle}
#
# ArchiveBox base URL — when set, bookmarks gain link-outs to view/archive their page on your
# self-hosted ArchiveBox (link-out only, no token sent). Can also be set from Settings → Connectors.
# ARCHIVEBOX_ENDPOINT=http://localhost:8000
#
# Kavita ebook/manga server — when both are set, bookmarks can be linked to a Kavita series
# ("View on Kavita" link-out + series cover import). The API key comes from Kavita's User Settings →
# API Key; the middleware exchanges it for a session token and never sends it to the browser.
# Both can also be set from Settings → Connectors.
# KAVITA_ENDPOINT=http://localhost:5000
# KAVITA_API_KEY=
#
# Locations geocoding (all keyless, default on). NOMINATIM_ENDPOINT overrides the OpenStreetMap
# Nominatim base used for place lookups. WIKIDATA_ENDPOINT is the fallback queried when Nominatim has
# no entry for a place (traditional / informal / natural regions with no admin boundary, e.g. 中国地方);
# WIKIMEDIA_MAPS_ENDPOINT is the Kartographer geoshape service used to pull a region's area outline.
# Point any of them at a self-hosted mirror to keep lookups on-box.
# NOMINATIM_ENDPOINT=https://nominatim.openstreetmap.org
# WIKIDATA_ENDPOINT=https://www.wikidata.org
# WIKIMEDIA_MAPS_ENDPOINT=https://maps.wikimedia.org
